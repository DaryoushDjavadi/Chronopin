rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function ownsLoginName(searchName) {
      return signedIn()
        && searchName is string
        && get(/databases/$(database)/documents/loginNames/$(searchName)).data.uid == request.auth.uid;
    }

    function isAdminUser() {
      return signedIn()
        && (ownsLoginName('admin') || ownsLoginName('dary') || ownsLoginName('daryoush'));
    }

    function isCoopParticipant(data) {
      return signedIn()
        && (data.hostPlayerId == request.auth.uid
            || data.guestUid == request.auth.uid
            || data.guestFriendId == request.auth.uid);
    }

    function isInviteParticipant(data) {
      return signedIn()
        && (data.fromPlayerId == request.auth.uid
            || data.toUid == request.auth.uid
            || data.toFriendId == request.auth.uid
            || (data.toSearchName is string && ownsLoginName(data.toSearchName)));
    }

    // Player profiles (search + avatar)
    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId)
        || (signedIn()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['migratedTo'])
            && request.resource.data.migratedTo == request.auth.uid
            && resource.data.searchName is string
            && ownsLoginName(resource.data.searchName))
        || (isAdminUser()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bonusStash', 'bonusHeartsNextRun']));
      allow delete: if isAdminUser();
    }

    // Unique login names → Firebase uid
    match /loginNames/{searchName} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdminUser();
    }

    // Friend requests
    match /friendRequests/{requestId} {
      allow read: if signedIn()
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid
            || (resource.data.toSearchName is string && ownsLoginName(resource.data.toSearchName)));
      allow create: if signedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string
        && request.resource.data.toSearchName is string
        && request.resource.data.status == 'pending';
      allow update: if signedIn()
        && (resource.data.toUid == request.auth.uid
            || resource.data.fromUid == request.auth.uid
            || (resource.data.toSearchName is string && ownsLoginName(resource.data.toSearchName)));
      allow delete: if false;
    }

    // Accepted friendships (required when accepting a request!)
    match /friendships/{friendshipId} {
      allow read: if signedIn()
        && (resource.data.userA == request.auth.uid
            || resource.data.userB == request.auth.uid);
      allow create: if signedIn()
        && (request.resource.data.userA == request.auth.uid
            || request.resource.data.userB == request.auth.uid);
      allow update, delete: if false;
    }

    // Co-op game rooms (live sync)
    match /coopRooms/{roomId} {
      allow read: if isCoopParticipant(resource.data);
      allow create: if signedIn()
        && request.resource.data.hostPlayerId == request.auth.uid
        && request.resource.data.guestUid is string;
      allow update: if isCoopParticipant(resource.data);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if signedIn()
          && isCoopParticipant(get(/databases/$(database)/documents/coopRooms/$(roomId)).data);
        allow create: if signedIn()
          && isCoopParticipant(get(/databases/$(database)/documents/coopRooms/$(roomId)).data)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.roomId == roomId
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 280
          && request.resource.data.at is number;
        allow update, delete: if false;
      }
    }

    // Co-op invites
    match /coopInvites/{inviteId} {
      allow read: if isInviteParticipant(resource.data);
      allow create: if signedIn()
        && request.resource.data.fromPlayerId == request.auth.uid
        && request.resource.data.toUid is string;
      allow update: if isInviteParticipant(resource.data);
      allow delete: if false;
    }

    // Chat (future)
    match /chats/{chatId}/messages/{messageId} {
      allow read, create: if signedIn()
        && chatId.matches('.*' + request.auth.uid + '.*');
      allow update, delete: if false;
    }

    // Global scoreboard — one best score per player per mode
    match /scoreboard/{entryId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.playerId == request.auth.uid
        && request.resource.data.searchName is string
        && ownsLoginName(request.resource.data.searchName)
        && request.resource.data.mode is string
        && request.resource.data.score is number
        && request.resource.data.rounds is number
        && (!resource.exists()
            || request.resource.data.score > resource.data.score
            || (request.resource.data.score == resource.data.score
                && request.resource.data.rounds >= resource.data.rounds));
      allow delete: if isAdminUser();
    }

    // Shared panorama difficulty ratings (1–3 stars) for library / future filters
    match /panoramaRatings/{panoId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 3
        && request.resource.data.updatedAt is number
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.updatedByName is string;
      allow delete: if signedIn();
    }

    // Player-reported faulty panoramas — admins review in library
    match /panoramaReports/{panoId} {
      allow read: if isAdminUser();
      allow create: if signedIn()
        && request.resource.data.panoId == panoId
        && request.resource.data.status == 'pending'
        && request.resource.data.reportCount is int
        && request.resource.data.reportCount >= 1
        && request.resource.data.updatedAt is number
        && request.resource.data.lastReporterUid == request.auth.uid
        && request.resource.data.lastReporterName is string;
      allow update: if isAdminUser()
        || (signedIn()
            && request.resource.data.panoId == panoId
            && request.resource.data.status == 'pending'
            && request.resource.data.lastReporterUid == request.auth.uid
            && request.resource.data.reportCount is int
            && request.resource.data.reportCount >= resource.data.reportCount);
      allow delete: if isAdminUser();
    }
  }
}
